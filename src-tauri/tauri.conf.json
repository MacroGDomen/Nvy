{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nvy",
  "version": "0.1.0",
  "identifier": "com.nvy.app",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nvy",
        "width": 1280,
        "height": 720,
        "minWidth": 1024,
        "minHeight": 576
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
